APP_ENV=dev
API_HOST=0.0.0.0
API_PORT=8000
USE_AWS_SERVICES=true

PROJECT_NAME="Agentic Document Platform"

# Architecture Config
CLOUD_PROVIDER=aws
RUNTIME_MODE=aws
PROCESSING_MODE=async
QUEUE_PROVIDER=sqs
STORAGE_PROVIDER=s3
KNOWLEDGE_PROVIDER=bedrock_kb
AGENT_PROVIDER=python_orchestrated

# AWS Specific Config
AWS_REGION=ap-south-1
AWS_PROFILE=divyang

S3BUCKETNAME=hay-agent-storage-dev-114644266543-ap-south-1
PROCESSEDFOLDERPREFIX=processed/
TEMPLATESFOLDERPREFIX=templates/


SQSQUEUEARN=arn:aws:sqs:ap-south-1:114644266543:hay-agent-queue-dev
SQSQUEUEURL=https://sqs.ap-south-1.amazonaws.com/114644266543/hay-agent-queue-dev



DBNAME=HayAgent

DATABASE_URL=postgresql+psycopg://dbadmin:HaysAdmin123!%23@hay-agent-db-dev.ctgoo20ag6cj.ap-south-1.rds.amazonaws.com:5432/HayAgent
STACKNAME=hay-agent-infra-dev
DBPORT=5432

BEDROCK_AGENT_ID=IUJ4II3JAI
BEDROCK_AGENT_ALIAS_ID=VYKEJ4BOMZ
BEDROCK_KB_ID=

# Document Parsing Routing & Guard
ENABLE_DOCLING=true
ENABLE_TIKA_FALLBACK=true
ENABLE_GPU_WORKER=false
PARSER_TIMEOUT_SECONDS=300
MAX_FILE_SIZE_MB=10

# LLM Settings
LLM_BACKEND=aws_bedrock
LLM_MODEL_NAME=meta.llama3-70b-instruct-v1:0
OLLAMA_ENDPOINT=http://localhost:11434/api/generate

# Storage Settings
LOCAL_STORAGE_PATH=./data

LOG_LEVEL=INFO

# Bedrock Model Routing
BEDROCK_TEMPLATE_ANALYSIS_MODEL_ID=qwen.qwen3-235b-a22b-2507-v1:0
BEDROCK_FALLBACK_MODEL_ID=qwen.qwen3-235b-a22b-2507-v1:0

# Bedrock Models - Llama 3 70B (Subscribed & Active)
LLM_PROVIDER=bedrock
LLM_MODEL_FAST=qwen.qwen3-235b-a22b-2507-v1:0
LLM_MODEL_STRONG=qwen.qwen3-235b-a22b-2507-v1:0
ENABLE_AUTH=false



