FROM nginx:1.27-alpine

ENV API_BASE_URL=http://localhost:8000 \
    PORTAL_BASE_PATH=/portal

COPY docker/nginx.frontend.conf /etc/nginx/conf.d/default.conf
COPY docker/frontend-config.template.js /tmp/frontend-config.template.js
COPY docker/frontend-entrypoint.sh /docker-entrypoint.d/40-hays-frontend-config.sh
COPY src/frontend/ /usr/share/nginx/html/portal/

RUN chmod +x /docker-entrypoint.d/40-hays-frontend-config.sh
